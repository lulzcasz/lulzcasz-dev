{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":semanticCommitTypeAll(build)"
  ],
  "timezone": "America/Sao_Paulo",
  "separateMultipleMajor": true,
  "packageRules": [
    {
      "description": "Group ALL minor and patch updates by their group names globally",
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "description": "Force ALL major updates to separate into individual package branches",
      "matchUpdateTypes": ["major"],
      "groupName": null
    },
    {
      "matchManagers": ["pep621"],
      "rangeStrategy": "bump",
      "matchDepNames": [
        "!python"
      ],
      "groupName": "python dependencies"
    },
    {
      "matchDepNames": ["python"],
      "enabled": true,
      "separateMultipleMinor": true,
      "commitMessageAction": "update",
      "commitMessageTopic": "python",
      "commitMessageExtra": "to {{newVersion}}"
    },
    {
      "matchManagers": ["dockerfile", "docker-compose"],
      "groupName": "docker images"
    },
    {
      "matchManagers": ["custom.regex"],
      "groupName": "frontend dependencies"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)Dockerfile$/"
      ],
      "matchStrings": [
        "ADD\\s+https://cdn\\.jsdelivr\\.net/npm/(?<depName>@[^/]+/[^@/]+|[^@/]+)@(?<currentValue>[^/]+)/"
      ],
      "datasourceTemplate": "npm"
    }
  ]
}
